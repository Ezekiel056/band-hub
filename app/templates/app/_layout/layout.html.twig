{% extends 'base.html.twig' %}
{% set currentRoute = app.request.attributes.get('_route') %}

{% block title %}{{pageTitle}}{% endblock %}


{% block body %}
  <div class="app-main-body">
    <header class="app-header">
      <div class="app-header-content">
         {{ include ('app/_layout/_band-selector.html.twig') }}

        <img class="header-logo" src="{{ asset('/images/logo_64.png') }}" alt="Band Hub logo">
        <h1>{{ pageTitle }}</h1>
        <button class="app-user-button">
          <img src="{{ asset('/images/icons/user.png') }}" alt="user icon">
        </button>
      </div>
    </header>

    <main class="app-main">
      {% block content %}{% endblock %}
    </main>

    <nav class="app-navbar">
      <div class="flex flex-col items-center">
        <img class="hidden navbar-logo" src="{{ asset('/images/logo_64.png') }}" alt="Band Hub logo">
       <p class="hidden app-nav-bar-heading">Band Hub</p>
      </div>
      <ul >
        <li {{ currentRoute == 'app_home' ? 'class="selected"' : '' }}>
          <a href="{{ path('app_home') }}">
            <div>
              <svg class="app-nav-bar-icon fill" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                <path  d="M13 9V3h8v6zM3 13V3h8v10zm10 8V11h8v10zM3 21v-6h8v6zm2-10h4V5H5zm10 8h4v-6h-4zm0-12h4V5h-4zM5 19h4v-2H5zm4-2" />
              </svg>
              <p class="hidden">Accueil</p>
            </div>
          </a>
        </li>


        <li {{ currentRoute == 'app_repertoire' ? 'class="selected"' : '' }}>
          <a href="{{ path('app_repertoire') }}">
            <div>
              <svg class="app-nav-bar-icon fill" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                <path  d="M20 2H8a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2m0 14H8V4h12m-7.5 11a2.5 2.5 0 0 0 2.5-2.5V7h3V5h-4v5.5c-.42-.31-.93-.5-1.5-.5a2.5 2.5 0 0 0-2.5 2.5a2.5 2.5 0 0 0 2.5 2.5M4 6H2v14a2 2 0 0 0 2 2h14v-2H4" />
              </svg>
              <p class="hidden">Repertoire</p>
            </div>
          </a>
        </li>

        <li {{ currentRoute == 'app_setlists' ? 'class="selected"' : '' }}>
          <a href="{{ path('app_home') }}">
            <div>
              <svg class="app-nav-bar-icon stroke" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24">
                <g fill="none"  stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5">
                  <path d="M3 15c0-2.809 0-4.213.674-5.222a4 4 0 0 1 1.104-1.104C5.787 8 7.19 8 10 8h4c2.809 0 4.213 0 5.222.674a4 4 0 0 1 1.104 1.104C21 10.787 21 12.19 21 15s0 4.213-.674 5.222a4 4 0 0 1-1.104 1.104C18.213 22 16.81 22 14 22h-4c-2.809 0-4.213 0-5.222-.674a4 4 0 0 1-1.104-1.104C3 19.213 3 17.81 3 15" />
