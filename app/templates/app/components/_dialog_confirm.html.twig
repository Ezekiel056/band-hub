<div data-confirm-target="dialog" class="modal !justify-end md:!justify-center ">
  <div class="card card-popup !py-12 !gap-14 !mb-10  md:max-w-xl">
    <div class="text-center flex flex-col gap-2">
      <p class="text-2xl text-(--label-color)" data-confirm-target="title">
      <p class="text-base text-(--text-color) empty:hidden" data-confirm-target="message"></p>
    </div>
    <div class="grid grid-cols-[1fr_1fr] gap-4">
      <button data-action="confirm#cancel" class="btn btn-secondary btn-square">Non</button>
      <button data-action="confirm#confirm" class="btn btn-danger btn-square ">Oui</button>
    </div>
  </div>
</div>
