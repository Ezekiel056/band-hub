{% extends 'app/_layout/layout.html.twig' %}
{% block stylesheets %}
  <link rel="stylesheet" href="{{ asset('styles/app/repertoire.css') }}">
{% endblock %}

{% block content %}

  <div class="hidden xl:flex justify-between pr-4">
    <p class="text-4xl font-semibold">{{ pageTitle }}</p>
    <button class="btn btn-primary !px-12">Proposer un morceau</button>
  </div>

  <nav class="navbar-tabs">
    <ul>
      <li>
        <button class="tab-item active">
          <span>Tous les morceaux</span>
          <span class="tag">10</span>
        </button>
      </li>
      <li>
        <button class="tab-item">
          <span>A voter</span>
          <span class="tag">10</span>
        </button>
      </li>
      <li>
        <button class="tab-item">
          <span>A apprendre</span>
          <span class="tag">10</span>
        </button>
      </li>
      <li>
        <button class="tab-item">
          <span>Validés</span>
          <span class="tag">10</span>
        </button>
      </li>

    </ul>
  </nav>

  <div class="search-input mr-3">
    <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M9.5 16q-2.725 0-4.612-1.888T3 9.5t1.888-4.612T9.5 3t4.613 1.888T16 9.5q0 1.1-.35 2.075T14.7 13.3l5.6 5.6q.275.275.275.7t-.275.7t-.7.275t-.7-.275l-5.6-5.6q-.75.6-1.725.95T9.5 16m0-2q1.875 0 3.188-1.312T14 9.5t-1.312-3.187T9.5 5T6.313 6.313T5 9.5t1.313 3.188T9.5 14"/></svg>
    <input type="text" placeholder="Rechercher une chanson">
  </div>

  <div class="scrollable-container pr-2">
    <div class="flex flex-col gap-10 md:grid md:grid-cols-2">
      {% for song in songs %}
        {{ include('/app/repertoire/_song-card.html.twig') }}
      {% endfor %}
    </div>
  </div>

  <div>
    footer
  </div>


  <button class="btn btn-primary add fixed bottom-[80px] right-[10px]">
    add
  </button>

{% endblock %}
