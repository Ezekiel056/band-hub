<turbo-frame id="modal"  >
  <div class="modal active" data-controller="modal">
    <div class="card card-popup max-w-[600px] ">
     <h2 class="text-3xl">Modifier les informations</h2>
      {{ form_start(form,{action: path('app_song_edit', {id: songId})}) }}
        {{ form_row(form.title) }}

        {# Artiste + bouton Add #}
        <div class="flex flex-col">
          {{ form_label(form.artist) }}
          <div class="grid grid-cols-[1fr_64px] gap-4">
            {{ form_widget(form.artist) }}
            <a role="button" type="button" data-turbo-frame="modal" href="{{ path('app_artist_create') }}"
               title="Ajouter un artiste" aria-label="Ajouter un artiste" class="btn btn-primary btn-square flex justify-center items-center ">
              <i class="icon icon-add icon-size-small !bg-white"></i>
            </a>
          </div>
          {{ form_errors(form.artist) }}
        </div>

        {{ form_rest(form) }}
        <div class="flex flex-col gap-4 md:flex-row-reverse">
          <button type="submit" class="btn btn-primary flex-1">Valider</button>
          <button type="button" class="btn btn-secondary md:w-1/3" data-action="modal#close" >Annuler</button>
        </div>
      {{ form_end(form) }}
    </div>
  </div>
</turbo-frame>
