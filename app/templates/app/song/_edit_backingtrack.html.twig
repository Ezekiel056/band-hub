<turbo-frame id="modal"  >
  <div class="modal active" data-controller="modal">
    <div class="card card-popup max-w-[600px] ">
      <h2 class="text-3xl">Modifier les informations</h2>
      {{ form_start(form,{action: path('app_backingtrack_edit',{id:backingtrack_id})}) }}
      {{ form_row(form.label) }}
      {{ form_row(form.instrument) }}

      <div class="flex flex-col gap-4 md:flex-row-reverse">
        <button type="submit" class="btn btn-primary flex-1">Valider</button>
        <button type="button" class="btn btn-secondary md:w-1/3" data-action="modal#close" >Annuler</button>
      </div>
      {{ form_end(form) }}
    </div>
  </div>
</turbo-frame>
