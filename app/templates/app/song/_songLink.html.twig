<li class="flex flex-col gap-2">
  <iframe class="w-full rounded-4xl"  height="250" src="{{ songLink.link ~ '&amp;controls=1' }}" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
  <div class="flex justify-between items-center">
    <h3 class="text-xl font-bold">{{ songLink.label }}</h3>
    <button data-action="confirm#open" type="button" aria-label="Supprimer le lien"
            data-confirm-url-param="{{ path('app_song_link_delete', {id: songLink.id}) }}"
            data-confirm-message-param="Voulez-vous supprimer le lien ?">
    <i class="icon icon-trash icon-size-small"></i></button>
  </div>
</li>
